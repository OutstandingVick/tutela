NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PRIVY_APP_ID=
# Optional if your Privy dashboard provides a client id for this app.
NEXT_PUBLIC_PRIVY_CLIENT_ID=
# Server-only Privy secret. Never prefix with NEXT_PUBLIC_ or commit a real value.
PRIVY_APP_SECRET=
NEXT_PUBLIC_TUTELA_PROGRAM_ID=GPhEqiNUU86oYW53NGUcS4DfZNCcYimiZuM5jaXwf1rG
NEXT_PUBLIC_MOCK_VERIFIER_PROGRAM_ID=8fRo2KWuFW4r9EBKVNKBN6AvzszFMU7hd6p9EXcCEGxv
NEXT_PUBLIC_TEST_USDC_MINT=
NEXT_PUBLIC_INDEXER_URL=http://localhost:8787
# Set to "txline" once TXLINE_API_TOKEN below is populated (run scripts/txline/activate.ts
# to obtain it); leave as "mock" to use the labelled simulated fallback adapter.
NEXT_PUBLIC_DATA_SOURCE=mock
NEXT_PUBLIC_TXLINE_MODE=txline-primary-with-simulated-fallback
NEXT_PUBLIC_TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
NEXT_PUBLIC_TXLINE_API_ORIGIN=https://txline-dev.txodds.com
# Confirmed against https://txline.txodds.com/documentation (2026-07-13):
TXLINE_API_BASE_URL=https://txline-dev.txodds.com/api
TXLINE_GUEST_AUTH_URL=https://txline-dev.txodds.com/auth/guest/start
TXLINE_ACTIVATE_URL=https://txline-dev.txodds.com/api/token/activate
TXLINE_TXL_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG
TXLINE_SERVICE_LEVEL_ID=1
TXLINE_DURATION_WEEKS=4
TXLINE_SELECTED_LEAGUES=
# Populated by scripts/txline/activate.ts:
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=
# Confirmed devnet World Cup fixture IDs (docs: /documentation/scores/schedule):
#   worldcup-sf-france-spain-2026-07-14     -> fixtureId 18237038 (Sat 14 Jul, 19:00 UTC)
#   worldcup-sf-england-argentina-2026-07-15 -> fixtureId 18241006 (Wed 15 Jul, 19:00 UTC)
# See packages/txline-adapter/src/index.ts (TXLINE_FIXTURE_MAP) for the mapping in code.
KEEPER_KEYPAIR_PATH=
INDEXER_PORT=8787
# Durable PostgreSQL is required for deployed balances and participation. Vercel's
# filesystem and SQLite are not durable across serverless invocations.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/tutela?sslmode=require
