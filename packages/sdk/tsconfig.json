{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@tutela/condition-engine": ["../condition-engine/src/index.ts"],
      "@tutela/solana-client": ["../solana-client/src/index.ts"],
      "@tutela/txline-adapter": ["../txline-adapter/src/index.ts"],
      "@tutela/types": ["../types/src/index.ts"],
      "@tutela/validation": ["../validation/src/index.ts"]
    },
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src"]
}
