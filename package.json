{
  "name": "tutela",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "corepack pnpm --filter @tutela/web dev",
    "build": "corepack pnpm -r build",
    "typecheck": "corepack pnpm -r typecheck",
    "test": "corepack pnpm -r test && vitest run tests/integration && cargo test -p tutela --lib",
    "test:anchor": "NO_DNA=1 anchor test",
    "seed": "tsx scripts/seed-demo.ts",
    "demo:settle": "tsx scripts/run-demo-settlement.ts",
    "demo:refund": "tsx scripts/run-demo-refund.ts",
    "validate:env": "tsx scripts/validate-environment.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.0",
    "axios": "^1.18.1",
    "tweetnacl": "^1.0.3"
  }
}
